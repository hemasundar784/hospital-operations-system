<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>appointment_cancellation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Status__c, &quot;Cancelled&quot;),
ISBLANK(Cancellation_Reason__c))</errorConditionFormula>
    <errorDisplayField>Cancellation_Reason__c</errorDisplayField>
    <errorMessage>&quot;A cancellation reason is
required to cancel an
appointment.&quot;</errorMessage>
</ValidationRule>
