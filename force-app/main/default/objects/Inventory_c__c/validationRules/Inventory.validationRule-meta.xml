<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Inventory</fullName>
    <active>true</active>
    <errorConditionFormula>Quantity_On_Hand__c &lt; 0</errorConditionFormula>
    <errorDisplayField>Quantity_On_Hand__c</errorDisplayField>
    <errorMessage>&quot;Physical inventory
quantities cannot fall
below zero.&quot;</errorMessage>
</ValidationRule>
