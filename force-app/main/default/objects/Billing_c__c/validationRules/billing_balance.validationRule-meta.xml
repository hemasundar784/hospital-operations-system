<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>billing_balance</fullName>
    <active>true</active>
    <errorConditionFormula>AND(Outstanding_Balance__c &gt; 0,
ISPICKVAL(Invoice_Status__c, &quot;Paid&quot;))</errorConditionFormula>
    <errorDisplayField>Invoice_Status__c</errorDisplayField>
    <errorMessage>&quot;Invoice cannot be
marked Paid while a
balance remains.&quot;</errorMessage>
</ValidationRule>
