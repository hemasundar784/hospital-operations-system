<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>totalPremiumOpportunities__c</fullName>
    <description>This will show the total premium opportunities available per this Account</description>
    <label>Total Premium Opportunities</label>
    <summaryFilterItems>
        <field>Opportunity.Amount</field>
        <operation>greaterOrEqual</operation>
        <value>500000</value>
    </summaryFilterItems>
    <summaryForeignKey>Opportunity.AccountId</summaryForeignKey>
    <summaryOperation>count</summaryOperation>
    <type>Summary</type>
</CustomField>
